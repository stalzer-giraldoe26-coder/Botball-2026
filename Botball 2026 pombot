// VARIABLES
// MOVEMENT
int left_motor = 0;
int right_motor = 1;
// ELABORATED MOVEMENT
// "basic" 
int forward()
{
    int speed = 50;
	motor(right_motor, speed);
	motor(left_motor, speed);
}

int forward_faster()
{
    int speed = 50;
	motor(right_motor, 100);
	motor(left_motor, 100);
}

int backward()
{
    int speed = 50;
	motor(right_motor, -speed);
	motor(left_motor, -speed);
}

int faster_backward()
{
    int speed = 50;
	motor(right_motor, -speed - 50);
	motor(left_motor, -speed - 50);
}
// "line-specific"
int long_turn_right()
{
    int speed = 50;
	motor(right_motor, speed);
	motor(left_motor, 0);
}

int long_turn_left()
{
    int speed = 50;
	motor(right_motor, 0);
	motor(left_motor, speed);
}

// "forward"
int line_veer_right()
{
    int speed = 50;
	motor(right_motor, speed + 15);
	motor(left_motor, speed - 10);
}

int line_veer_left()
{
    int speed = 50;
	motor(right_motor, 0);
	motor(left_motor, speed + 35);
}

// "forward"
int REVERSE_line_veer_right()
{
    int speed = 50;
	motor(right_motor, - 60);
	motor(left_motor, - speed);
}

int REVERSE_line_veer_left()
{
    int speed = 50;
	motor(right_motor, -85);
	motor(left_motor, 0);
}
// ------------------------------
int angle_turn_left()
{
    int speed = 50;
	motor(right_motor, 0);
	motor(left_motor, speed + 35);
}

int angle_turn_right()
{
    int speed = 50;
	motor(right_motor, speed + 35);
	motor(left_motor, 0);
}

int super_angle_turn_left()
{
    int speed = 50;
	motor(right_motor, 0);
	motor(left_motor, speed + 50);
}

int REVERSE_angle_turn_left()
{
    int speed = 50;
	motor(right_motor, 0);
	motor(left_motor, -85);
}
